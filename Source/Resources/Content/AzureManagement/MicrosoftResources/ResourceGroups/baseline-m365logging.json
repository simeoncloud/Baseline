{
  "$description": "| What does this do? | Creates an Azure Event Hub, Azure Log Analytics Workspace, and Azure Storage account to capture Azure and Intune logs. |\n| Why should you use this? | This provides the essential resources required to capture logs, analyze trends, and be alerted of suspicious events. |\n| What is the end-user impact? | N/A |\n| Learn more | [Designing your Azure Monitor Logs deployment](https://docs.microsoft.com/en-us/azure/azure-monitor/platform/design-logs-deployment) |",
  "$schema": "https://schema.management.azure.com/schemas/2014-04-01-preview/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "outputs": {
    "resourceName": {
      "type": "String",
      "value": "[variables('defaultResourceName')]"
    }
  },
  "parameters": {
    "eventHubMessageRetentionInDays": {
      "defaultValue": 1,
      "type": "Int"
    },
    "eventHubSku": {
      "allowedValues": [
        "Basic",
        "Standard"
      ],
      "defaultValue": "Basic",
      "metadata": {
        "description": "Specifies the messaging tier for service bus namespace."
      },
      "type": "String"
    },
    "logAnalyticsWorkspaceSku": {
      "allowedValues": [
        "PerGB2018",
        "PerNode",
        "Standalone"
      ],
      "defaultValue": "PerGB2018",
      "metadata": {
        "description": "Specifies the service tier of the workspace: Standalone, PerNode, Per-GB"
      },
      "type": "String"
    }
  },
  "resources": [
    {
      "apiVersion": "2015-11-01-preview",
      "location": "[resourceGroup().location]",
      "name": "[variables('defaultResourceName')]",
      "properties": {
        "features": {
          "searchVersion": 1
        },
        "sku": {
          "Name": "[parameters('logAnalyticsWorkspaceSku')]"
        }
      },
      "type": "Microsoft.OperationalInsights/workspaces"
    },
    {
      "apiVersion": "2017-04-01",
      "dependsOn": [
        "[resourceId('Microsoft.EventHub/namespaces', variables('defaultResourceName'))]"
      ],
      "location": "[resourceGroup().location]",
      "name": "[concat(variables('defaultResourceName'), '/hub')]",
      "properties": {
        "messageRetentionInDays": "[parameters('eventHubMessageRetentionInDays')]",
        "partitionCount": 1
      },
      "type": "Microsoft.EventHub/namespaces/eventhubs"
    },
    {
      "apiVersion": "2017-04-01",
      "location": "[resourceGroup().location]",
      "name": "[variables('defaultResourceName')]",
      "properties": {
        "isAutoInflateEnabled": false,
        "maximumThroughputUnits": 0
      },
      "sku": {
        "capacity": 1,
        "name": "[parameters('eventHubSku')]",
        "tier": "[parameters('eventHubSku')]"
      },
      "type": "Microsoft.EventHub/namespaces"
    },
    {
      "apiVersion": "2019-06-01",
      "dependsOn": [],
      "kind": "StorageV2",
      "location": "[resourceGroup().location]",
      "name": "[variables('defaultResourceName')]",
      "properties": {
        "accessTier": "Hot",
        "largeFileSharesState": "Disabled",
        "supportsHttpsTrafficOnly": "true"
      },
      "sku": {
        "name": "Standard_LRS"
      },
      "tags": {},
      "type": "Microsoft.Storage/storageAccounts"
    }
  ],
  "variables": {
    "defaultResourceName": "[concat(replace(replace(resourceGroup().name, 'baseline-', ''), '-', ''), variables('suffix'))]",
    "suffix": "[uniqueString(subscription().subscriptionId)]"
  }
}